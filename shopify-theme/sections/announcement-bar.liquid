<div class="announcement-bar">
  <div class="page-width announcement-bar__inner">
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>
        {{ block.settings.text }}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Localized pricing across USD, EUR, and GBP"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
