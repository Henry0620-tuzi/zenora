<section class="section-space">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.collection != blank %}
        <a class="muted-link" href="{{ section.settings.collection.url }}">{{ 'sections.featured_collection.view_all' | t }}</a>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      <div class="product-grid">
        {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product_card_product: product, index: forloop.index %}
        {% endfor %}
      </div>
    {% else %}
      <div class="product-grid">
        {% for i in (1..3) %}
          {% render 'product-card', product_card_product: blank, index: forloop.index %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hero pieces that carry the ZENORA point of view with premium restraint."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
