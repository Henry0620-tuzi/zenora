<div class="cart-drawer" data-cart-drawer hidden>
  <div class="cart-drawer__backdrop" data-cart-drawer-close></div>
  <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="CartDrawerTitle" aria-describedby="CartDrawerStatus" tabindex="-1">
    <div class="cart-drawer__header">
      <h2 id="CartDrawerTitle">{{ 'cart.drawer_title' | t }}</h2>
      <button type="button" class="cart-drawer__close" data-cart-drawer-close aria-label="{{ 'cart.close' | t }}">×</button>
    </div>
    <div id="CartDrawerStatus" class="cart-drawer__status" data-cart-drawer-status role="status" aria-live="polite" aria-atomic="true"></div>
    <div class="cart-drawer__body" data-cart-drawer-body>
      {% render 'cart-drawer-items', cart: cart %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
