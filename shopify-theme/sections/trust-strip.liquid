<section>
  <div class="trust-strip__inner page-width">
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>
        {{ block.settings.text }}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Trust strip",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Clear size guidance"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        { "type": "item", "settings": { "text": "Clean silhouettes shaped for weekday movement" } },
        { "type": "item", "settings": { "text": "Premium tone without visual excess" } },
        { "type": "item", "settings": { "text": "Fit guidance built for cross-border conversion" } },
        { "type": "item", "settings": { "text": "Women-led assortment with a menswear extension" } }
      ]
    }
  ]
}
{% endschema %}
